{
  "name": "backend",
  "version": "1.0.2",
  "description": "Express application for the MAU Arkiv project",
  "main": "src/app.ts",
  "scripts": {
    "start": "ts-node src/app.ts",
    "build": "npm run build-frontend && npm run copy-frontend && tsc && npm run copy-assets",
    "build-frontend": "npm run build --prefix ../frontend",
    "copy-assets": "cp -r public dist/public",
    "copy-frontend": "cp -r ../frontend/dist/browser/* public/",
    "dev": "ts-node-dev --respawn src/app.ts",
    "test:logging": "ts-node scripts/test-logging.ts",
    "migrate:latest": "knex migrate:latest --knexfile dist/src/core/config/knex-config.js",
    "migrate:rollback": "knex migrate:rollback --knexfile dist/src/core/config/knex-config.js",
    "migrate:make": "knex migrate:make --knexfile src/core/config/knex-config.ts -x ts",
    "migrate:latest:dev": "knex migrate:latest --knexfile src/core/config/knex-config.ts",
    "migrate:rollback:dev": "knex migrate:rollback --knexfile src/core/config/knex-config.ts"
  },
  "dependencies": {
    "@mau-arkiv/shared": "file:../shared",
    "@types/express-session": "^1.18.2",
    "@types/saml2-js": "^3.0.4",
    "axios": "^1.13.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "express-session": "^1.18.2",
    "hjson": "^3.2.2",
    "knex": "^3.1.0",
    "mssql": "^11.0.1",
    "reflect-metadata": "^0.2.2",
    "saml2-js": "^4.0.4",
    "tedious": "^19.1.3",
    "ts-node": "^10.9.2",
    "tsyringe": "^4.10.0",
    "typescript": "^4.5.4",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/config": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.13",
    "@types/hjson": "^2.4.6",
    "@types/mssql": "^9.1.5",
    "@types/node": "^16.11.7",
    "@types/winston": "^2.4.4",
    "@types/xml2js": "^0.4.14",
    "config": "^4.1.1",
    "express": "^4.18.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^4.5.4"
  },
  "author": "",
  "license": "ISC"
}
