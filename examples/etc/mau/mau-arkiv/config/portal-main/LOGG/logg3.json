    "forms": [
        {
            "title": "Åtkomstlogg sök", 
            "uid": "9_1_001_auditlog_form", 
            "description": "<p>Här söker du på åtkomstloggen för arkivet.</p>",            
            "database": {
    	        "connection": "Arkiv_app",
    	        "statement": '''
                BEGIN
      			DECLARE @v1 NVARCHAR(200);
      			DECLARE @v2 NVARCHAR(200);
      			DECLARE @v3 NVARCHAR(200);
                DECLARE @v4 DATETIME;


      			SET @v1 = ?;
      			SET @v2 = ?;
      			SET @v3 = ?;
                SET @v4 = ?;
        SELECT
			[user], 
            verb, 
            url, 
            createdAt, 
            LEFT(body, 200) AS body
	FROM
			[dbo].[AuditLog]
	WHERE
          (@v1 = '' OR [AuditLog].[user] LIKE '%'+@v1+'%' )
          AND (@v2 = '' OR [AuditLog].[url] LIKE '%'+@v2+'%' )
          AND (@v3 = '' OR [AuditLog].[createdAt] >= @v3 )
          AND (@v4 = '' OR [AuditLog].[createdAt] <= @v4 )
	ORDER BY {0}
        OFFSET (({1} - 1) * {2}) ROWS
        FETCH NEXT {2} ROWS ONLY
        OPTION(RECOMPILE);
	END''',
    "countStatement": '''
       BEGIN
      			DECLARE @v1 NVARCHAR(200);
      			DECLARE @v2 NVARCHAR(200);
      			DECLARE @v3 NVARCHAR(200);
                DECLARE @v4 NVARCHAR(200);


      			SET @v1 = ?;
      			SET @v2 = ?;
      			SET @v3 = ?;
                SET @v4 = ?;
        SELECT
		COUNT(id) 
	FROM
			[dbo].[AuditLog]
	WHERE
          (@v1 = '' OR [AuditLog].[user] LIKE '%'+@v1+'%' )
          AND (@v2 = '' OR [AuditLog].[url] LIKE '%'+@v2+'%' )
          AND (@v3 = '' OR [AuditLog].[createdAt] >= @v3 )
          AND (@v4 = '' OR [AuditLog].[createdAt] <= @v4 )

	OPTION(RECOMPILE);
       END
      '''
    },
