            "database": {
                "connection": "Arkiv_test",
                "statement": 
		"\n\t\tBEGIN\n                    DECLARE @v1 NVARCHAR(200);\n                    DECLARE @v2 NVARCHAR(200);\n\n                    SET @v1 = ?;\n                    SET @v2 = ?;\n\n                SELECT\n                    [TestIndex].[PERSONNUMMER],\n                    [TestIndex].[DATUM],\n                    [TestIndex].[uri]\n                FROM\n                    [dbo].[TestIndex]\n                WHERE\n                    (@v1 = '' OR [TestIndex].[PERSONNUMMER] LIKE '%'+@v1+'%' )\n                    AND (@v2 = '' OR [TestIndex].[DATUM] LIKE '%'+@v2+'%' )\n                ORDER BY {0}\n                OFFSET (({1} - 1) * {2}) ROWS\n                FETCH NEXT {2} ROWS ONLY\n                OPTION(RECOMPILE);\n            END",
                "countStatement": "\n                BEGIN\n                    DECLARE @v1 NVARCHAR(200);\n                    DECLARE @v2 NVARCHAR(200);\n\n                    SET @v1 = ?;\n                    SET @v2 = ?;\n\n                SELECT\n                    COUNT(*)\n                FROM\n                    [dbo].[TestIndex]\n                WHERE\n                    (@v1 = '' OR [TestIndex].[PERSONNUMMER] LIKE '%'+@v1+'%' )\n                    AND (@v2 = '' OR [TestIndex].[DATUM] LIKE '%'+@v2+'%' )\n                OPTION(RECOMPILE);\n            END\n        ",
